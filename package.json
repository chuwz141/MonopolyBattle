{
  "name": "monopolybattle",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:shared": "npm run watch --workspace=shared",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently --kill-others \"npm run dev:shared\" \"npm run dev:server\" \"npm run dev:client\"",
    "db:seed": "npm run seed --workspace=server",
    "build:shared": "npm run build --workspace=shared",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build": "npm run build:shared && npm run build:server && npm run build:client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
